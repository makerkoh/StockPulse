# Database
DATABASE_URL="postgresql://stockpulse:stockpulse@localhost:5432/stockpulse?schema=public"

# Auth — generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-random-32-char-hex-string"

# App password — generate hash with: npm run hash-password yourpassword
# Default for dev: "stockpulse" (bcrypt hash below)
APP_PASSWORD_HASH="$2a$10$placeholder"

# Data Providers (optional — runs in demo mode without these)
FINNHUB_API_KEY=""
FMP_API_KEY=""
ALPHA_VANTAGE_API_KEY=""
NEWS_API_KEY=""

# App
NEXT_PUBLIC_APP_NAME="StockPulse"
NODE_ENV="development"
